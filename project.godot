config_version=5

[application]

config/name="VOID PROTOCOL"
config/description="Strategic Isometric Battle Royale - The last signal in a dead galaxy."
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.6", "GL Compatibility")
